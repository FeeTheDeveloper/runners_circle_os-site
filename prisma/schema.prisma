generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  EDITOR
  ANALYST
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum CampaignStatus {
  DRAFT
  PLANNED
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ContentPlatform {
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  TIKTOK
  EMAIL
  SMS
  WEB
}

enum ContentStatus {
  DRAFT
  REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum LeadStatus {
  NEW
  QUALIFIED
  NURTURING
  WON
  LOST
}

enum PublicSubmissionType {
  CONSULTATION
  INTAKE
  ONBOARDING
}

enum JobType {
  CONTENT_PUBLISH
  CRM_SYNC
  LEAD_ENRICHMENT
  REPORT_EXPORT
  AUDIENCE_REFRESH
  GENERATE_IMAGE
  GENERATE_VIDEO
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum AccountStatus {
  ACTIVE
  PAUSED
  DISCONNECTED
}

enum IntegrationStatus {
  PENDING
  CONNECTED
  DEGRADED
  DISCONNECTED
}

enum IntegrationProvider {
  CRM    @map("crm")
  SOCIAL @map("social")
}

enum CreatorRequestType {
  IMAGE
  VIDEO
}

enum CreatorRequestStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum GeneratedAssetType {
  IMAGE
  VIDEO
}

enum GeneratedAssetStatus {
  READY
  FAILED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String?
  role         UserRole   @default(OPERATOR)
  status       UserStatus @default(INVITED)
  lastSeenAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  campaignsCreated        Campaign[]
  contentItemsCreated     ContentItem[]
  audienceSegmentsCreated AudienceSegment[]
  leadsCreated            Lead[]
  creatorRequestsCreated  CreatorRequest[]
  generatedAssetsCreated  GeneratedAsset[]

  @@index([role, status])
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  objective   String
  description String?
  status      CampaignStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  createdById String?

  createdBy       User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  contentItems    ContentItem[]
  creatorRequests CreatorRequest[]
  generatedAssets GeneratedAsset[]

  @@index([status])
  @@index([startDate, endDate])
}

model ContentItem {
  id           String          @id @default(cuid())
  title        String
  platform     ContentPlatform
  format       String
  copy         String
  mediaUrl     String?
  status       ContentStatus   @default(DRAFT)
  scheduledFor DateTime?
  publishedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  campaignId   String?
  createdById  String?

  campaign        Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdBy       User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  generatedAssets GeneratedAsset[]

  @@index([platform, status])
  @@index([campaignId])
  @@index([scheduledFor])
}

model AudienceSegment {
  id          String   @id @default(cuid())
  name        String
  description String?
  marketLane  String?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  leads     Lead[]
  createdBy User?  @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([marketLane])
}

model Lead {
  id                String             @id @default(cuid())
  firstName         String
  lastName          String
  email             String             @unique
  company           String?
  source            String?
  status            LeadStatus         @default(NEW)
  tags              String[]           @default([])
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  segmentId         String?
  createdById       String?
  publicSubmissions PublicSubmission[]

  segment   AudienceSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  createdBy User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([segmentId])
  @@index([source])
  @@index([createdById])
}

model PublicSubmission {
  id          String               @id @default(cuid())
  type        PublicSubmissionType
  source      String
  email       String
  name        String?
  company     String?
  payload     Json
  summary     Json?
  requestMeta Json?
  createdAt   DateTime             @default(now())
  leadId      String?

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([source])
  @@index([email])
  @@index([leadId])
}

model AutomationJob {
  id           String    @id @default(cuid())
  type         JobType
  status       JobStatus @default(QUEUED)
  scheduledFor DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  payload      Json?
  result       Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([type, status])
  @@index([scheduledFor])
}

model CreatorRequest {
  id          String               @id @default(cuid())
  type        CreatorRequestType
  templateKey String
  platform    ContentPlatform
  format      String
  brandSlug   String
  headline    String
  body        String
  cta         String
  status      CreatorRequestStatus @default(QUEUED)
  payload     Json
  campaignId  String?
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  campaign        Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdBy       User             @relation(fields: [createdById], references: [id])
  generatedAssets GeneratedAsset[]

  @@index([type, status])
  @@index([campaignId])
  @@index([createdById])
}

model GeneratedAsset {
  id          String               @id @default(cuid())
  requestId   String
  assetType   GeneratedAssetType
  title       String
  url         String
  storageKey  String?
  width       Int?
  height      Int?
  durationSec Int?
  status      GeneratedAssetStatus @default(READY)
  metadata    Json
  campaignId  String?
  contentId   String?
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  request   CreatorRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  campaign  Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  content   ContentItem?   @relation(fields: [contentId], references: [id], onDelete: SetNull)
  createdBy User           @relation(fields: [createdById], references: [id])

  @@index([requestId])
  @@index([assetType, status])
  @@index([campaignId])
  @@index([contentId])
  @@index([createdById])
}

model ChannelAccount {
  id                      String          @id @default(cuid())
  platform                ContentPlatform
  accountName             String
  accountId               String
  status                  AccountStatus   @default(ACTIVE)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  integrationConnectionId String?

  integrationConnection IntegrationConnection? @relation(fields: [integrationConnectionId], references: [id], onDelete: SetNull)

  @@unique([platform, accountId])
  @@index([status])
}

model IntegrationConnection {
  id           String              @id @default(cuid())
  provider     IntegrationProvider
  status       IntegrationStatus   @default(PENDING)
  metadata     Json?
  lastSyncedAt DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  channelAccounts ChannelAccount[]

  @@unique([provider])
  @@index([status])
}
